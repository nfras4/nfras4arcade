{
  "name": "nfras4arcade",
  "version": "1.0.0",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260405.1",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "svelte": "^5.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "wrangler": "^4.80.0"
  },
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "dev:client": "bunx --bun vite dev",
    "dev:server": "bun --watch server/index.ts",
    "build": "vite build && bun scripts/patch-worker.ts",
    "deploy": "bun run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 execute nfras4arcade-db --local --yes --file=migrations/0001_initial.sql",
    "db:migrate:prod": "wrangler d1 execute nfras4arcade-db --remote --file=migrations/0001_initial.sql",
    "preview": "vite preview"
  },
  "type": "module",
  "dependencies": {
    "canvas-confetti": "^1.9.4"
  }
}
